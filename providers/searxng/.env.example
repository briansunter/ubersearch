# SearXNG Configuration
# Copy this file to .env and update values

# Secret key for SearXNG (generate with: openssl rand -hex 32)
SEARXNG_SECRET=your-secret-key-here

# API key for ubersearch integration
# Generate with: openssl rand -hex 16
SEARXNG_API_KEY=your-ubersearch-api-key-here

# Host paths bind-mounted into the container.
# The ubersearch launcher sets these automatically and respects XDG_CONFIG_HOME /
# XDG_DATA_HOME. Set them here only if you invoke `docker compose` by hand — the
# compose file falls back to these defaults when the variables are unset.
# SEARXNG_CONFIG=${HOME}/.config/ubersearch/searxng/config
# SEARXNG_DATA=${HOME}/.local/share/ubersearch/searxng/data

# Bind address (usually don't need to change)
# SEARXNG_BIND_ADDRESS=0.0.0.0:8080
